# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/gateway

# Redis
REDIS_URL=redis://redis:6379/0

# LLM Providers (Add yours)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
EMBEDDING_MODEL=text-embedding-3-small

# Admin
ADMIN_API_KEY=your-admin-secret-key

# Budget & Cost Limiting
BUDGET_ENABLED=true
DEFAULT_BUDGET=1000.0
DEFAULT_COST_PER_REQUEST=0.001

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Semantic Cache
CACHE_ENABLED=true
CACHE_SIMILARITY_THRESHOLD=0.95

# PII Masking
PII_MASKING_ENABLED=true

# Model Routing (JSON, optional - falls back to built-in defaults)
# MODEL_ROUTES=[{"pattern":"gpt-4*","provider":"openai"},{"pattern":"*","provider":"openai","fallback":"ollama/llama3"}]
